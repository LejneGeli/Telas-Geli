# Copie este arquivo para .env quando rodar fora do Docker.
# No Docker Compose, as variáveis abaixo já são usadas como padrão.
NODE_ENV=development
PORT=3000

DB_HOST=postgres
DB_PORT=5432
DB_NAME=mosquiteiras_db
DB_USER=mosquiteiras_user
DB_PASSWORD=mosquiteiras_password

REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=8h
